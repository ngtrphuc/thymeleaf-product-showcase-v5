# Copy to .env for local development. Keep real values out of Git.

SPRING_PROFILES_ACTIVE=dev

# Database
DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartphone_shop
DATASOURCE_USER=smartphone
DATASOURCE_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# Initial admin bootstrap. Leave blank to skip creating/updating the admin user.
ADMIN_EMAIL=admin@smartphone.local
ADMIN_PASSWORD=ChangeMe123!

# JWT secret must be at least 32 bytes. Use a unique value per environment.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_MINUTES=120

# Frontend/API
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
